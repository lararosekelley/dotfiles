{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin",
  "model": "openai/gpt-5.2-codex",
  "autoupdate": true,
  "mcp": {
    "magic-patterns": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.magicpatterns.com/mcp",
    },
    "linear": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.linear.app/mcp",
    },
    "github": {
      "type": "remote",
      "enabled": true,
      "url": "https://api.githubcopilot.com/mcp",
      "oauth": {
        "clientId": "{env:GITHUB_OPENCODE_CLIENT_ID}",
        "clientSecret": "{env:GITHUB_OPENCODE_CLIENT_SECRET}",
        "scope": "tools:read tools:execute",
      },
    },
    "sentry": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {},
    },
  },
}
