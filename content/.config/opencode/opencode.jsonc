{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.3-codex",
  "autoupdate": true,
  "mcp": {
    "circleci": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "-y", "@circleci/mcp-server-circleci@latest"],
      "environment": {
        "CIRCLECI_TOKEN": "{env:CIRCLE_TOKEN}",
        "CIRCLECI_BASE_URL": "https://circleci.com",
      },
    },
    "magic-patterns": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.magicpatterns.com/mcp",
    },
    "linear": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.linear.app/mcp",
    },
    "github": {
      "type": "remote",
      "enabled": true,
      "url": "https://api.githubcopilot.com/mcp",
      "oauth": {
        "clientId": "{env:GITHUB_OPENCODE_CLIENT_ID}",
        "clientSecret": "{env:GITHUB_OPENCODE_CLIENT_SECRET}",
        "scope": "tools:read tools:execute",
      },
    },
    "sentry": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {},
    },
    "datadog": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.us5.datadoghq.com/api/unstable/mcp-server/mcp",
      "oauth": {},
    },
    "aws": {
      "type": "local",
      "enabled": true,
      "command": [
        "uvx",
        "mcp-proxy-for-aws@latest",
        "https://aws-mcp.us-east-1.api.aws/mcp",
      ],
      "environment": {
        "AWS_REGION": "{env:AWS_REGION}",
      },
    },
  },
}
