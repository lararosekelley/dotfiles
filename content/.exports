#!/usr/bin/env bash

# exports
#
# global variables
# --------

# english & utf-8

export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# set neovim to default editor

export EDITOR="nvim"

# increase history size & ignore duplicates, make sure history is shared (see .bash_prompt for more)

export HISTSIZE="100000"
export HISTFILESIZE="${HISTSIZE}"
export HISTTIMEFORMAT="%F %T "
export HISTCONTROL="ignoredups:erasedups"

# appimagelauncher needs this

export QT_QPA_PLATFORM=xcb

# ollama / local llm's

export OLLAMA_API_BASE="http://127.0.0.1:11434"

# go

export GOPATH="$HOME/.go"
export GOBIN="$GOPATH/bin"

# lua

export LUAROCKS_CONFIG="$HOME/.luarocks/config-5.4.lua"

# rust

export CARGO_PATH="$HOME/.cargo"

# fly.io

export FLYCTL_INSTALL="$HOME/.fly"

# perl

export PERL_MM_OPT="$HOME/perl5"

# pyenv

export PYENV_ROOT="$HOME/.pyenv"
export PYENV_VIRTUALENV_DISABLE_PROMPT=1

# ignore python 2 deprecation warnings

export PYTHONWARNINGS="ignore:DEPRECATION"

# mutt

export COLORFGBG="default;default"

# nodenv

export NODENV_PATH="$HOME/.nodenv/bin"

# rbenv

export RBENV_PATH="$HOME/.rbenv/bin"

# snaps

export SNAP_PATH="/var/lib/snapd/snap"

# path

path_prepend_if_missing "$FLYCTL_INSTALL/bin"
path_prepend_if_missing "$HOME/.opencode/bin"
path_prepend_if_missing "$SNAP_PATH/bin"
path_prepend_if_missing "$CARGO_PATH/bin"
path_prepend_if_missing "$GOBIN"
path_prepend_if_missing "$PYENV_ROOT/bin"
path_prepend_if_missing "$NODENV_PATH"
path_prepend_if_missing "$RBENV_PATH"
path_prepend_if_missing "$HOME/.poetry/bin"
path_prepend_if_missing "$HOME/.local/bin"
path_prepend_if_missing "$HOME/.bin"

export PATH
